// Passport & Movable Box Tracking System
// Prisma Schema — derived from system diagram
//
// Conventions (see CONVENTIONS.md):
//   - All location/capacity mutations go through LocationService.moveBox()
//   - No direct writes to movableBox / passport / movementLog outside their services
//   - Every move operation updates locationId AND writes a MovementLog in one transaction

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  // url moved to prisma.config.ts (Prisma 7 requirement)
}

// ---------------------------------------------------------------------------
// Physical storage hierarchy: Room → Shelf → Row → MovableBox
// ---------------------------------------------------------------------------

model Room {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Room A"
  qrCode    String   @unique // QR on the physical room
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shelves Shelf[]

  @@map("rooms")
}

model Shelf {
  id        String   @id @default(cuid())
  name      String   // e.g. "Shelf 01"
  qrCode    String   @unique
  position  Int      // ordinal position within the room
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roomId String
  room   Room   @relation(fields: [roomId], references: [id])

  rows Row[]

  @@unique([roomId, name])
  @@map("shelves")
}

model Row {
  id        String   @id @default(cuid())
  name      String   // e.g. "Row A", "Row B"
  qrCode    String   @unique
  position  Int      // ordinal position within the shelf
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shelfId String
  shelf   Shelf  @relation(fields: [shelfId], references: [id])

  slots Slot[]

  @@unique([shelfId, name])
  @@map("rows")
}

model Slot {
  id        String   @id @default(cuid())
  name      String   // e.g. "Slot 1", "Slot 2"
  qrCode    String   @unique
  position  Int      // position within the row
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rowId String
  row   Row    @relation(fields: [rowId], references: [id])

  boxes MovableBox[]

  @@unique([rowId, name])
  @@map("slots")
}

// ---------------------------------------------------------------------------
// Movable Box
// Capacity is fixed at 10 per diagram. occupiedCount is maintained by the
// service layer — never updated directly outside LocationService.
// ---------------------------------------------------------------------------

model MovableBox {
  id            String    @id @default(cuid())
  qrCode        String    @unique // QR label on the physical box, e.g. "MB-0001"
  label         String    @unique // human-readable label, e.g. "MB-0001"
  capacity      Int       @default(10)
  occupiedCount Int       @default(0)
  status        BoxStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Current physical location — null if box is not placed in a slot yet
  slotId String? @unique
  slot   Slot?   @relation(fields: [slotId], references: [id])

  passports    Passport[]
  movementLogs MovementLog[]

  // Derived: vacantCount = capacity - occupiedCount (computed in service, not stored)
  @@map("movable_boxes")
}

enum BoxStatus {
  ACTIVE
  FULL
  INACTIVE
}

// ---------------------------------------------------------------------------
// Passport
// Status drives the key business state machine:
//   IN_BOX  → ISSUED  (Issue to owner)
//   ISSUED  → IN_BOX  (Return from owner)
// ---------------------------------------------------------------------------

model Passport {
  id           String         @id @default(cuid())
  qrCode       String         @unique // QR on the physical passport document
  holderName   String
  holderIdNo   String         @unique // national/document ID number
  status       PassportStatus @default(IN_BOX)
  dateReturned DateTime?      // last return date
  dateIssued   DateTime?      // last issue date
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Current box — null when passport is issued to owner
  boxId String?
  box   MovableBox? @relation(fields: [boxId], references: [id])

  movementLogs MovementLog[]

  @@map("passports")
}

enum PassportStatus {
  IN_BOX // stored in a movable box
  ISSUED // issued to its owner, not in any box
}

// ---------------------------------------------------------------------------
// Movement Log — append-only audit trail
// One record per action. Never update or delete these rows.
// Written by LocationService inside the same transaction as the mutation.
// ---------------------------------------------------------------------------

model MovementLog {
  id           String     @id @default(cuid())
  action       LogAction
  fromLocation String?    // human-readable: "Room A / Shelf 01 / Row A" or null if newly entered
  toLocation   String?    // null if issued to owner (leaving the system)
  notes        String?
  createdAt    DateTime   @default(now())

  // One of these will be set depending on the action type
  passportId String?
  passport   Passport? @relation(fields: [passportId], references: [id])

  boxId String?
  box   MovableBox? @relation(fields: [boxId], references: [id])

  // The staff member who performed the action
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("movement_logs")
}

enum LogAction {
  PASSPORT_ASSIGNED  // passport placed into a box
  PASSPORT_RETURNED  // passport returned from owner into a box
  PASSPORT_ISSUED    // passport issued to owner (removed from box)
  BOX_MOVED          // box moved to a new row/shelf/room (cascades to all passports)

  // Configuration Audit Actions
  ROOM_CREATED
  ROOM_UPDATED
  ROOM_DELETED

  SHELF_CREATED
  SHELF_UPDATED
  SHELF_DELETED

  ROW_CREATED
  ROW_UPDATED
  ROW_DELETED

  SLOT_CREATED
  SLOT_UPDATED
  SLOT_DELETED
}

// ---------------------------------------------------------------------------
// User — staff who operate the mobile app or web admin portal
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movementLogs MovementLog[]

  @@map("users")
}

enum UserRole {
  ADMIN // full web portal access
  STAFF // mobile app + search only
}
