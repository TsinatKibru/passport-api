# Copy this to .env and fill in real values
# Never commit .env to git

# Database
DATABASE_URL="postgresql://passport_user:passport_pass@localhost:5432/passport_track"

# Environment
NODE_ENV="development"

# JWT — change this to a long random secret in production
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"

# Server
PORT=3000

# Admin portal URL (for CORS)
ADMIN_URL="http://localhost:3001"

# SMTP Mailer Configurations
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@passport-track.com"
